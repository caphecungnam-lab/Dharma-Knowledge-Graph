{
  "family": "dkg-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/dkg-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/dkg-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/dkg-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "DEBUG",
          "value": "false"
        },
        {
          "name": "QDRANT_PORT",
          "value": "6333"
        },
        {
          "name": "DKG_RATE_LIMIT_PER_MINUTE",
          "value": "120"
        }
      ],
      "secrets": [
        {
          "name": "DKG_API_KEY",
          "valueFrom": "/dkg/prod/api-key"
        },
        {
          "name": "DKG_JWT_SECRET",
          "valueFrom": "/dkg/prod/jwt-secret"
        },
        {
          "name": "DKG_ADMIN_USER",
          "valueFrom": "/dkg/prod/admin-user"
        },
        {
          "name": "DKG_ADMIN_PASSWORD",
          "valueFrom": "/dkg/prod/admin-password"
        },
        {
          "name": "DKG_CORS_ORIGINS",
          "valueFrom": "/dkg/prod/cors-origins"
        },
        {
          "name": "NEO4J_URI",
          "valueFrom": "/dkg/prod/neo4j-uri"
        },
        {
          "name": "NEO4J_USER",
          "valueFrom": "/dkg/prod/neo4j-user"
        },
        {
          "name": "NEO4J_PASSWORD",
          "valueFrom": "/dkg/prod/neo4j-password"
        },
        {
          "name": "QDRANT_HOST",
          "valueFrom": "/dkg/prod/qdrant-host"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "/dkg/prod/redis-url"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=5)\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dkg-api",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}
