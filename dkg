#!/bin/bash

case "$1" in
  start)
    echo "🌌 Starting Dharma Knowledge Graph..."
    docker compose up --build
    ;;

  stop)
    echo "🛑 Stopping Dharma Knowledge Graph..."
    docker compose down
    ;;

  restart)
    echo "🔄 Restarting Dharma Knowledge Graph..."
    docker compose down
    docker compose up --build
    ;;

  logs)
    docker compose logs -f
    ;;

  status)
    docker compose ps
    ;;

  check-api)
    bash scripts/dkg027_connection_check.sh
    ;;

  health)
    echo "⚙️ DKG container health:"
    docker compose ps
    echo ""
    echo "🔎 API port check:"
    curl -s -o /dev/null -w "API HTTP status: %{http_code}\n" http://localhost:8000/docs
    echo ""
    echo "Note: 401 means API is running but protected by auth."
    ;;

  *)
    echo "Usage: ./dkg start | stop | restart | logs | status | health | check-api"
    ;;
esac
