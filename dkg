#!/bin/bash

case "$1" in
  start)
    echo "🌌 Starting Dharma Knowledge Graph..."
    docker compose up --build
    ;;

  stop)
    echo "🛑 Stopping Dharma Knowledge Graph..."
    docker compose down
    ;;

  restart)
    echo "🔄 Restarting Dharma Knowledge Graph..."
    docker compose down
    docker compose up --build
    ;;

  logs)
    docker compose logs -f
    ;;

  status)
    docker compose ps
    ;;

  health)
    echo "⚙️ API health:"
    curl -fsS http://localhost:8000/health || curl -fsS http://localhost:8000/docs
    ;;

  *)
    echo "Usage: ./dkg start | stop | restart | logs | status | health"
    ;;
esac
